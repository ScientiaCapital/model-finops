# ============================================================================
# AI STACK OPTIMIZER - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your API keys
# Get keys from the direct links below (one-click to exact page)
#
# Quick Start:
#   cp .env.template .env
#   # Fill in your keys
#   python scripts/validate_api_keys.py  # Test all keys
# ============================================================================

# ============================================================================
# LLM PROVIDERS
# ============================================================================

# Anthropic Claude (Required for Claude models)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google AI / Gemini
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenRouter (50+ models via single API - DeepSeek, Qwen, Claude, etc.)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq (Ultra-fast LPU inference - Llama 3.3 70B)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras (Wafer-scale inference - 1000+ tok/s)
# Get key: https://cloud.cerebras.ai/platform
CEREBRAS_API_KEY=

# Together AI (Fine-tuned models, LoRAs)
# Get key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Hugging Face (Models, Spaces, Inference API)
# Get token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ============================================================================
# VOICE AI - Text-to-Speech (TTS)
# ============================================================================

# Cartesia (Real-time voice synthesis - Sonic)
# Get key: https://play.cartesia.ai/console
# Pricing: $0.042/second
CARTESIA_API_KEY=

# ElevenLabs (Premium voice cloning)
# Get key: https://elevenlabs.io/app/settings/api-keys
# Pricing: $0.30/1000 chars (Starter), $0.18/1000 chars (Pro)
ELEVENLABS_API_KEY=

# ============================================================================
# VOICE AI - Speech-to-Text (STT)
# ============================================================================

# Deepgram (Fast, accurate STT - Nova 2)
# Get key: https://console.deepgram.com/project/*/keys
# Pricing: $0.0043/minute (Nova 2)
DEEPGRAM_API_KEY=

# AssemblyAI (Advanced transcription, speaker diarization)
# Get key: https://www.assemblyai.com/app/account
# Pricing: $0.0037/second
ASSEMBLYAI_API_KEY=

# ============================================================================
# INFRASTRUCTURE - Database & Deployment
# ============================================================================

# Supabase (PostgreSQL, Auth, Storage, Realtime)
# Get from: https://supabase.com/dashboard/project/_/settings/api
# Required for: Multi-tenant data, semantic caching, RLS
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_PASSWORD=

# Vercel (Frontend Deployment)
# Get token: https://vercel.com/account/tokens
# Get IDs: https://vercel.com/account/tokens → Project Settings
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Railway (Backend Deployment)
# Get token: https://railway.app/account/tokens
RAILWAY_API_TOKEN=

# RunPod (GPU Inference)
# Get key: https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=

# ============================================================================
# AI MEDIA - Video & Image Generation
# ============================================================================

# Runway (AI Video Generation)
# Get key: https://app.runwayml.com/account/api-keys
RUNWAY_API_KEY=

# ============================================================================
# OBSERVABILITY - Tracing & Monitoring
# ============================================================================

# LangSmith (LLM tracing, debugging, evaluation)
# Get key: https://smith.langchain.com/settings
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-stack-optimizer

# ============================================================================
# BILLING - Stripe Integration
# ============================================================================

# Stripe (Subscription billing)
# Get keys: https://dashboard.stripe.com/apikeys
# IMPORTANT: Use test keys (sk_test_*) for development!
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create in Stripe Dashboard)
# Products: https://dashboard.stripe.com/products
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=

# ============================================================================
# APPLICATION CONFIG
# ============================================================================

# Server
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO
DEBUG=false

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://ai-cost-optimizer-scientia-capital.vercel.app

# ============================================================================
# ML / EMBEDDING CONFIG
# ============================================================================

# Embedding model for semantic caching
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu  # or 'cuda' for GPU pods

# Semantic cache settings
SIMILARITY_THRESHOLD=0.95  # 0-1, higher = stricter matching

# Model cache directory (for RunPod volume mount)
TORCH_HOME=/app/model_cache

# ============================================================================
# OPTIONAL - Advanced Configuration
# ============================================================================

# RunPod API (for deployment scripts)
# Get key: https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=

# GitHub (for CI/CD)
# Get token: https://github.com/settings/tokens
GITHUB_TOKEN=

# Docker Hub (for image pushing)
# Username: your Docker Hub username
DOCKER_USERNAME=
DOCKER_PASSWORD=

# ============================================================================
# DEVELOPMENT ONLY - Do not use in production
# ============================================================================

# Test user credentials (for local development only)
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=testpassword123
